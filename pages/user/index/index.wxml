<view class='UCenter-bg'>
    <image src='/img/logo.png' class='png' mode='widthFix'></image>
    <view class='text-xl'> 暴走的火腿 </view>
    <image src='https://image.weilanwl.com/gif/wave.gif' mode='scaleToFill' class='gif-wave'></image>
</view>
<view class='padding flex text-center text-grey bg-white shadow-warp'>
    <view class='flex flex-sub flex-direction solid-right'>
        <view class="text-xxl text-orange">{{processingCount}}</view>
        <view class="margin-top-sm">
            <text class='icon-recharge'></text> 进行任务数</view>
    </view>
    <view class='flex flex-sub flex-direction solid-right'>
        <view class="text-xxl text-blue">{{overdueCount}}</view>
        <view class="margin-top-sm">
            <text class='icon-moneybag'></text> 超时任务数</view>
    </view>
    <view class='flex flex-sub flex-direction'>
        <view class="text-xxl text-green">{{finishedCount}}</view>
        <view class="margin-top-sm">
            <text class='icon-sponsor'></text> 完成任务数</view>
    </view>
</view>
<view class="cu-list menu card-menu margin-top-xl margin-bottom-xl shadow-lg">
    <view class="cu-item arrow">
        <navigator class='content' open-type="navigate" hover-class='none' url="/pages/user/mytask/index">
            <text class='icon-send text-cyan'></text>
            <text class='text-grey'>我的任务</text>
        </navigator>
    </view>
    <view class="cu-item arrow">
        <navigator class='content' open-type="navigate" hover-class='none' url="/pages/user/information/index">
            <text class='icon-location text-orange'></text>
            <text class='text-grey'>我的信息</text>
        </navigator>
    </view>
    <view class="cu-item arrow">
        <button class='cu-btn content' open-type='feedback'>
            <text class='icon-writefill text-grey'></text>
            <text class='text-grey'>意见反馈</text>
        </button>
    </view>
</view>
